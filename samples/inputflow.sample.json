{
  "Version": 2,
  "Startup": false,
  "ShowTrayIcon": true,
  "LogLevel": "Info",
  "Workflows": [
    {
      "Id": "korean-toggle",
      "Name": "Korean toggle",
      "Mode": "toggle",
      "Triggers": [
        {
          "Keys": "Ctrl+Alt+Shift+K"
        }
      ],
      "Target": "korean",
      "ReturnBehavior": "alwaysSpecificLayout",
      "Fallback": "us-intl"
    }
  ],
  "Profiles": [
    {
      "Id": "us-intl",
      "Match": {
        "KLID": "00020409",
        "LanguageTag": null,
        "LayoutNameContains": null,
        "ProfileNameContains": null
      },
      "EnterMode": null
    },
    {
      "Id": "korean",
      "Match": {
        "LanguageTag": "ko-KR",
        "KLID": null,
        "LayoutNameContains": null,
        "ProfileNameContains": null
      },
      "EnterMode": "hangul"
    }
  ],
  "ExcludedProcesses": [
    "mstsc.exe",
    "vmconnect.exe"
  ]
}
